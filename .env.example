ELEPHAS_DB_BACKEND=sqlite
ELEPHAS_DB_DSN=file:elephas.db
ELEPHAS_HTTP_PORT=8080
ELEPHAS_HTTP_READ_TIMEOUT_MS=30000
ELEPHAS_HTTP_WRITE_TIMEOUT_MS=30000

# Optional auth
# ELEPHAS_API_KEY=change-me

# Optional extractor
# ELEPHAS_EXTRACTOR_ENDPOINT=https://api.openai.com/v1/chat/completions
# ELEPHAS_EXTRACTOR_API_KEY=$OPENAI_API_KEY
# ELEPHAS_EXTRACTOR_MODEL=gpt-4o
# ELEPHAS_EXTRACTOR_TIMEOUT_MS=30000
# ELEPHAS_EXTRACTOR_MAX_CANDIDATES=50

# Search and resolution defaults
ELEPHAS_SEARCH_DEFAULT_LIMIT=20
ELEPHAS_SEARCH_MAX_LIMIT=100
ELEPHAS_RESOLVE_THRESHOLD=0.85

# Optional Redis cache
# ELEPHAS_CACHE_DSN=redis://127.0.0.1:6379/0
# ELEPHAS_CACHE_TTL_SECONDS=300

# Postgres example
# ELEPHAS_DB_BACKEND=postgres
# ELEPHAS_DB_DSN=postgres://localhost:5432/elephas?sslmode=disable

# AGE example
# ELEPHAS_DB_BACKEND=age
# ELEPHAS_DB_DSN=postgres://localhost:5432/elephas?sslmode=disable
